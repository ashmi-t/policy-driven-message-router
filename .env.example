# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/message_router

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# Twilio (SMS): https://console.twilio.com → Account SID, Auth Token, buy a number
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+15551234567

# Mailjet (Email): https://app.mailjet.com → Account → API keys (Key + Secret), use verified sender
MAILJET_API_KEY=your_api_key
MAILJET_API_SECRET=your_api_secret
MAILJET_FROM_EMAIL=your-sender@example.com
MAILJET_FROM_NAME=Message Router
